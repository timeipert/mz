<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Source: {{source.quellensigle}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { 
      background-color: #f4f6f9; 
      font-family: 'Inter', sans-serif;
      color: #2d3748;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
    }
    .header-bar { 
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); 
      color: white; 
      padding: 2.5rem 0; 
      margin-bottom: 2.5rem; 
      border-bottom: 4px solid #3b82f6;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .btn-back {
      border-radius: 8px;
      font-weight: 500;
      font-size: 0.85rem;
      border: 1px solid rgba(255,255,255,0.25);
      color: white;
      transition: all 0.2s ease;
    }
    .btn-back:hover {
      background: rgba(255,255,255,0.1);
      border-color: white;
      color: white;
    }
    .sidebar-card { 
      background: white; 
      padding: 2rem; 
      border-radius: 12px; 
      box-shadow: 0 4px 15px rgba(0,0,0,0.02); 
      border: 1px solid #e2e8f0;
      margin-bottom: 2rem;
    }
    .content-area { 
      background: white; 
      padding: 2.5rem; 
      border-radius: 16px; 
      box-shadow: 0 10px 25px rgba(0,0,0,0.03); 
      border: 1px solid rgba(226, 232, 240, 0.8);
    }
    .metadata-row { 
      border-bottom: 1px solid #f1f5f9; 
      padding: 0.75rem 0; 
    }
    .metadata-row:last-child {
      border-bottom: none;
    }
    .metadata-label { 
      font-weight: 600; 
      color: #718096; 
      font-size: 0.8rem; 
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .metadata-value {
      font-weight: 500;
      color: #1a202c;
      margin-top: 2px;
    }
    .doc-item {
      border: 1px solid #e2e8f0;
      border-radius: 10px;
      padding: 1.25rem;
      margin-bottom: 1rem;
      background: #ffffff;
      transition: all 0.2s ease;
      text-decoration: none !important;
      display: flex !important;
      align-items: center;
      justify-content: space-between;
    }
    .doc-item:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px rgba(0,0,0,0.05);
      border-color: #3b82f6;
    }
    .search-box {
      position: relative;
    }
    .search-box i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #a0aec0;
    }
    .search-input {
      padding-left: 38px !important;
      border-radius: 8px;
      border: 1px solid #cbd5e1;
      transition: all 0.2s ease;
    }
    .search-input:focus {
      border-color: #3b82f6;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
    }
    {{{globalCss}}}
    {{{customCss}}}
  </style>
</head>
<body>

  {{#if headerHtml}}
    <div class="container-fluid px-5 pt-4">
      {{{headerHtml}}}
    </div>
  {{/if}}

  <div class="header-bar shadow-sm">
    <div class="container-fluid px-5">
      <a href="index.html" class="btn btn-sm btn-back px-3 py-2 mb-3"><i class="bi bi-arrow-left me-1"></i>Back to Index</a>
      <h2 class="mb-0 text-white">{{source.quellensigle}}</h2>
    </div>
  </div>

  <div class="container-fluid px-5 flex-grow-1">
    <div class="row">
      <!-- Sidebar for Metadata -->
      <div class="col-md-4 col-lg-3">
        <div class="sidebar-card">
          <h4 class="mb-3 border-bottom pb-2 text-slate-800"><i class="bi bi-info-circle text-primary me-2"></i>Details</h4>
          {{#each metadata}}
          <div class="metadata-row">
            <div class="metadata-label">{{this.label}}</div>
            <div class="metadata-value">{{this.value}}</div>
          </div>
          {{/each}}
        </div>
      </div>
      
      <!-- Main Content for Documents -->
      <div class="col-md-8 col-lg-9">
        <div class="content-area">
          <div class="row align-items-center mb-4 g-3">
            <div class="col-sm-6">
              <h3 class="mb-0 text-slate-800"><i class="bi bi-file-earmark-music text-primary me-2"></i>Documents ({{documents.length}})</h3>
            </div>
            <div class="col-sm-6 text-sm-end">
              <div class="search-box d-inline-block w-100" style="max-width: 320px;">
                <i class="bi bi-search"></i>
                <input type="text" id="searchInput" class="form-control search-input" placeholder="Search documents..." onkeyup="filterDocs()">
              </div>
            </div>
          </div>

          <div id="docsList">
            {{#each documents}}
            <a href="{{../source.id}}/{{this.id}}.html" class="doc-item">
              <div>
                <h5 class="mb-1 text-slate-800">{{this.title}}</h5>
                <span class="text-muted small fw-medium"><i class="bi bi-calendar-event me-1"></i>Date: {{this.date}}</span>
              </div>
              <div class="d-flex align-items-center gap-3">
                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-3 py-1.5 small">{{this.genre}}</span>
                <i class="bi bi-chevron-right text-muted fs-5"></i>
              </div>
            </a>
            {{/each}}
          </div>
        </div>
      </div>
    </div>
  </div>

  {{#if footerHtml}}
    {{{footerHtml}}}
  {{else}}
    <footer class="mt-auto py-4 border-top text-center text-muted small bg-white">
      <p class="mb-0">&copy; 2026 Monodi Project. All rights reserved.</p>
    </footer>
  {{/if}}

  <script>
    function filterDocs() {
      const input = document.getElementById("searchInput").value.toLowerCase();
      const items = document.querySelectorAll("#docsList .doc-item");
      items.forEach(item => {
        const text = item.innerText.toLowerCase();
        item.style.setProperty('display', text.includes(input) ? 'flex' : 'none', 'important');
      });
    }
  </script>
</body>
</html>
