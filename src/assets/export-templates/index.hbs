<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Monodi Project Index</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { 
      background-color: #f4f6f9; 
      font-family: 'Inter', sans-serif;
      color: #2d3748;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    h1, h2, h3, h4, h5, h6, .page-title {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
    }
    .header-bar { 
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); 
      color: white; 
      padding: 3rem 0; 
      margin-bottom: 2.5rem; 
      border-bottom: 4px solid #34d399;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .main-container { 
      background: white; 
      padding: 2.5rem; 
      border-radius: 16px; 
      box-shadow: 0 10px 25px rgba(0,0,0,0.03); 
      margin-bottom: 3rem;
      border: 1px solid rgba(226, 232, 240, 0.8);
    }
    .badge-doc-count {
      background-color: #ecfdf5;
      color: #059669;
      font-weight: 600;
      border: 1px solid #a7f3d0;
    }
    .search-box {
      position: relative;
    }
    .search-box i {
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      color: #a0aec0;
    }
    .search-input {
      padding-left: 38px !important;
      border-radius: 8px;
      border: 1px solid #cbd5e1;
      transition: all 0.2s ease;
    }
    .search-input:focus {
      border-color: #34d399;
      box-shadow: 0 0 0 3px rgba(52, 211, 153, 0.15);
    }
    .table-hover tbody tr {
      transition: background-color 0.15s ease;
    }
    .table-hover tbody tr:hover {
      background-color: #f8fafc;
    }
    .source-link {
      color: #0f172a;
      transition: color 0.15s ease;
      font-weight: 700;
    }
    .source-link:hover {
      color: #059669;
    }
    .btn-view {
      border-radius: 6px;
      font-weight: 500;
      font-size: 0.85rem;
      padding: 0.4rem 0.85rem;
      transition: all 0.2s ease;
    }
    .btn-view:hover {
      transform: translateY(-1px);
    }
    .frontpage-wrapper {
      margin-bottom: 2.5rem;
    }
    {{{globalCss}}}
    {{{customCss}}}
  </style>
</head>
<body>
  
  <div class="frontpage-wrapper">
    {{#if frontpageHtml}}
      {{{frontpageHtml}}}
    {{else}}
      <div class="header-bar">
        <div class="container">
          <div class="d-flex align-items-center gap-3">
            <div class="bg-emerald-500 rounded-3 p-2 d-inline-flex" style="background: rgba(52, 211, 153, 0.2);">
              <i class="bi bi-book-half text-emerald-400 fs-1 text-success"></i>
            </div>
            <div>
              <h1 class="mb-0 text-white">Monodi Project</h1>
              <p class="lead mb-0 mt-1 text-white-50">Static offline compilation. Generated on {{generationDate}}</p>
            </div>
          </div>
        </div>
      </div>
    {{/if}}
  </div>

  <div class="container flex-grow-1">
    <div class="main-container">
      <div class="row align-items-center mb-4 g-3">
        <div class="col-sm-6">
          <h3 class="mb-0 text-slate-800"><i class="bi bi-journal-album text-primary me-2"></i>Sources Index</h3>
        </div>
        <div class="col-sm-6 text-sm-end">
          <div class="search-box d-inline-block w-100" style="max-width: 320px;">
            <i class="bi bi-search"></i>
            <input type="text" id="searchInput" class="form-control search-input" placeholder="Search sources..." onkeyup="filterTable()">
          </div>
        </div>
      </div>

      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0" id="indexTable">
          <thead class="table-light border-bottom">
            <tr>
              <th style="cursor: pointer; padding: 1rem;" onclick="sortTable(0)">Source Title <i class="bi bi-arrow-down-up small text-muted ms-1"></i></th>
              <th style="padding: 1rem;">Metadata</th>
              <th class="text-end" style="padding: 1rem;">Documents</th>
            </tr>
          </thead>
          <tbody>
            {{#each sources}}
            <tr>
              <td class="fs-5" style="padding: 1.25rem 1rem;">
                <a href="source_{{this.id}}.html" class="source-link text-decoration-none">{{this.title}}</a>
              </td>
              <td style="padding: 1.25rem 1rem;">
                <div class="row g-2">
                  {{#each this.metadata}}
                  <div class="col-md-6 col-lg-4 small">
                    <span class="text-muted text-uppercase fw-semibold" style="font-size: 0.75rem;">{{this.label}}:</span>
                    <span class="d-block text-dark fw-medium mt-0.5">{{this.value}}</span>
                  </div>
                  {{/each}}
                </div>
              </td>
              <td class="text-end" style="padding: 1.25rem 1rem;">
                <span class="badge badge-doc-count rounded-pill px-3 py-2">{{this.documents.length}} documents</span>
                <a href="source_{{this.id}}.html" class="btn btn-sm btn-outline-primary btn-view ms-2"><i class="bi bi-eye me-1"></i>Open</a>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  {{#if footerHtml}}
    {{{footerHtml}}}
  {{else}}
    <footer class="mt-auto py-4 border-top text-center text-muted small bg-white">
      <p class="mb-0">&copy; 2026 Monodi Project. All rights reserved.</p>
    </footer>
  {{/if}}

  <script>
    function filterTable() {
      const input = document.getElementById("searchInput").value.toLowerCase();
      const rows = document.querySelectorAll("#indexTable tbody tr");
      rows.forEach(row => {
        const text = row.innerText.toLowerCase();
        row.style.setProperty('display', text.includes(input) ? '' : 'none', 'important');
      });
    }

    function sortTable(n) {
      var table, rows, switching, i, x, y, shouldSwitch, dir, switchcount = 0;
      table = document.getElementById("indexTable");
      switching = true;
      dir = "asc"; 
      while (switching) {
        switching = false;
        rows = table.getElementsByTagName("TR");
        for (i = 1; i < (rows.length - 1); i++) {
          shouldSwitch = false;
          x = rows[i].getElementsByTagName("TD")[n];
          y = rows[i + 1].getElementsByTagName("TD")[n];
          if (dir == "asc") {
            if (x.innerText.toLowerCase() > y.innerText.toLowerCase()) { shouldSwitch= true; break; }
          } else if (dir == "desc") {
            if (x.innerText.toLowerCase() < y.innerText.toLowerCase()) { shouldSwitch = true; break; }
          }
        }
        if (shouldSwitch) {
          rows[i].parentNode.insertBefore(rows[i + 1], rows[i]);
          switching = true;
          switchcount ++;      
        } else {
          if (switchcount == 0 && dir == "asc") {
            dir = "desc";
            switching = true;
          }
        }
      }
    }
  </script>
</body>
</html>
