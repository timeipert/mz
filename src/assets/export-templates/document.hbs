<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Document: {{document.title}}</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { 
      background-color: #f4f6f9; 
      font-family: 'Inter', sans-serif;
      color: #2d3748;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Outfit', sans-serif;
      font-weight: 700;
    }
    .header-bar { 
      background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%); 
      color: white; 
      padding: 2.5rem 0; 
      margin-bottom: 2.5rem; 
      border-bottom: 4px solid #10b981;
      box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
    .btn-back {
      border-radius: 8px;
      font-weight: 500;
      font-size: 0.85rem;
      border: 1px solid rgba(255,255,255,0.25);
      color: white;
      transition: all 0.2s ease;
    }
    .btn-back:hover {
      background: rgba(255,255,255,0.1);
      border-color: white;
      color: white;
    }
    .sidebar-card { 
      background: white; 
      padding: 2rem; 
      border-radius: 12px; 
      box-shadow: 0 4px 15px rgba(0,0,0,0.02); 
      border: 1px solid #e2e8f0;
      margin-bottom: 2rem;
    }
    .content-area { 
      background: white; 
      padding: 2.5rem; 
      border-radius: 16px; 
      box-shadow: 0 10px 25px rgba(0,0,0,0.03); 
      border: 1px solid rgba(226, 232, 240, 0.8);
      overflow-x: auto; 
    }
    .metadata-row { 
      border-bottom: 1px solid #f1f5f9; 
      padding: 0.75rem 0; 
    }
    .metadata-row:last-child {
      border-bottom: none;
    }
    .metadata-label { 
      font-weight: 600; 
      color: #718096; 
      font-size: 0.8rem; 
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .metadata-value {
      font-weight: 500;
      color: #1a202c;
      margin-top: 2px;
    }
    
    /* Monodi-light static viewer overrides */
    app-notes, app-line-change, app-folio-change, app-clef, app-box { 
      display: inline-block !important; 
      vertical-align: top; 
      margin-right: 0px !important; 
      margin-bottom: 8px; 
    }
    /* Hide editor-specific interactive elements and pitch strings */
    .dropdown, button, .deleteData, app-dragger, .edit-btn, .type-identifier, .para-comment-button, .root-line,
    .noteText:not(.syllableText), .dnone, .d-none { 
      display: none !important; 
    }
    .formteil-line { border: none !important; margin: 0 !important; }
    .read-only .formteil-section { margin-top: 0; padding-top: 0; border: none; }
    
    /* Interactive comment highlights */
    [data-uuid].has-comment {
      cursor: pointer;
      border-bottom: 2px dashed #10b981;
      transition: background-color 0.15s ease;
    }
    [data-uuid].has-comment:hover {
      background-color: rgba(16, 185, 129, 0.1);
    }
    .lemma-klammer { cursor: pointer; }

    /* Pull syllable text closer to SVG */
    .read-only svg {
      height: 70px !important;
    }
    .syllableText:not(.dnone):not(.d-none) {
      margin-top: -15px !important;
      display: block !important;
      text-align: center !important;
    }

    /* Injected custom styles */
    {{{globalCss}}}
    {{{customCss}}}
  </style>
</head>
<body>

  {{#if headerHtml}}
    <div class="container-fluid px-5 pt-4">
      {{{headerHtml}}}
    </div>
  {{/if}}

  <div class="header-bar shadow-sm">
    <div class="container-fluid px-5">
      <a href="../source_{{sourceId}}.html" class="btn btn-sm btn-back px-3 py-2 mb-3"><i class="bi bi-arrow-left me-1"></i>Back to Source</a>
      <h2 class="mb-0 text-white">{{document.title}}</h2>
      <p class="text-white-50 mb-0">Document ID: {{document.id}}</p>
    </div>
  </div>

  <div class="container-fluid px-5 flex-grow-1">
    <div class="row">
      <!-- Sidebar for Metadata -->
      <div class="col-md-4 col-lg-3">
        <div class="sidebar-card">
          <h4 class="mb-3 border-bottom pb-2 text-slate-800"><i class="bi bi-info-circle text-primary me-2"></i>Document Info</h4>
          {{#each metadata}}
          <div class="metadata-row">
            <div class="metadata-label">{{this.label}}</div>
            <div class="metadata-value">{{this.value}}</div>
          </div>
          {{/each}}
        </div>
      </div>
      
      <!-- Main Content for Rendered Chants -->
      <div class="col-md-8 col-lg-9">
        <div class="content-area monodi-rendered-content">
          <h3 class="mb-4 text-slate-800 border-bottom pb-2"><i class="bi bi-music-note-beamed text-primary me-2"></i>Transcription</h3>
          <!-- The fully rendered Angular SVG/HTML goes here -->
          {{{renderedHtml}}}
        </div>
      </div>
    </div>
  </div>

  <!-- Modal for Comments -->
  <div class="modal fade" id="commentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content shadow-lg border-0 rounded-4">
        <div class="modal-header bg-light border-bottom-0 py-3 px-4">
          <h5 class="modal-title text-emerald-800 fw-bold"><i class="bi bi-chat-left-text text-success me-2"></i>Scholarly Commentary</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body p-4" id="commentModalBody">
          <!-- Populated by JS -->
        </div>
      </div>
    </div>
  </div>

  {{#if footerHtml}}
    {{{footerHtml}}}
  {{else}}
    <footer class="mt-auto py-4 border-top text-center text-muted small bg-white">
      <p class="mb-0">&copy; 2026 Scholarly Monodi Edition Project. All rights reserved.</p>
    </footer>
  {{/if}}

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script type="application/json" id="monodi-data">
    {{{rawJsonData}}}
  </script>
  
  <script>
    document.addEventListener("DOMContentLoaded", function() {
      const docData = JSON.parse(document.getElementById('monodi-data').textContent);
      console.log("Loaded MonodiJSON data:", docData);

      if (docData.comments && docData.comments.length > 0) {
        const commentModal = new bootstrap.Modal(document.getElementById('commentModal'));
        const modalBody = document.getElementById('commentModalBody');

        // Map all elements with data-uuid that have comments
        docData.comments.forEach(comment => {
          const elements = document.querySelectorAll(`[data-uuid="${comment.startUUID}"], [data-uuid="${comment.endUUID}"]`);
          
          elements.forEach(el => {
            el.classList.add('has-comment');
            
            el.addEventListener('click', (e) => {
              e.preventDefault();
              e.stopPropagation();
              
              let html = `<h4>${comment.emendation || 'Note'}</h4>`;
              if (comment.text) html += `<p>${comment.text}</p>`;
              
              if (comment.lines && comment.lines.length > 0) {
                html += '<div class="table-responsive mt-3"><table class="table table-bordered table-sm">';
                comment.lines.forEach(row => {
                  html += '<tr>';
                  row.forEach(cell => html += `<td>${cell || ''}</td>`);
                  html += '</tr>';
                });
                html += '</table></div>';
              }
              
              modalBody.innerHTML = html;
              commentModal.show();
            });
          });
        });
      }
    });
  </script>
</body>
</html>
